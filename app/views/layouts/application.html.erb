<!DOCTYPE html>
<html lang="ja">
  <head>
    <title>App</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  </head>

  <body>
    <nav class="navbar navbar-dark bg-dark">
      <div class="container">
        <%= link_to "勤怠システム", root_path, class: "navbar-brand fw-bold" %>

        <div class="d-flex gap-3">
          <% if user_signed_in? %>
            <%= link_to "トップへ", root_path, class: "nav-link text-white" %>
            <% if admin_user? %>
              <%= link_to "ユーザー一覧", users_path, class: "nav-link text-white" %>
              <%= link_to "基本情報の修正", edit_basic_info_user_path(current_user), class: "nav-link text-white" %>
            <% end %>
            <div class="dropdown">
              <a href="#" class="nav-link text-white dropdown-toggle" data-bs-toggle="dropdown">
                アカウント
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><%= link_to "勤怠", user_path(current_user), class: "dropdown-item" %></li>
                <li><%= link_to "設定", edit_user_registration_path, class: "dropdown-item" %></li>
                <li><hr class="dropdown-divider"></li>
                <li><%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item" %></li>
              </ul>
            </div>
          <% else %>
            <%= link_to "トップへ", root_path, class: "nav-link text-white" %>
            <%= link_to "ログイン", new_user_session_path, class: "nav-link text-white" %>
          <% end %>
        </div>
      </div>
    </nav>

    <% flash_type_map = { "notice" => "success", "alert" => "danger", "error" => "danger", "warning" => "warning" } %>
    <% flash.each do |type, message| %>
      <div class="alert alert-<%= flash_type_map[type.to_s] || type %> alert-dismissible fade show m-2" role="alert">
        <%= message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>
    <%= yield %>
  </body>
</html>
