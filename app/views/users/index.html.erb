<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-start mb-3">
    <h2><%= params[:name].present? ? "検索結果" : "全てのユーザー" %></h2>

    <div class="card p-3 search-card">
      <div class="fw-bold mb-2">ユーザー名検索</div>
      <%= form_with url: users_path, method: :get, local: true do |f| %>
        <div class="input-group">
          <%= f.text_field :name, value: params[:name],
                          placeholder: "キーワードを入力...", class: "form-control form-control-sm" %>
          <%= f.submit "検索", class: "btn btn-primary btn-sm" %>
        </div>
      <% end %>
    </div>
  </div>

  <%= will_paginate @users, renderer: Bootstrap5LinkRenderer,
                   previous_label: "前へ", next_label: "次へ" %>

  <table class="table table-bordered table-hover mt-2">
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td>
            <%= link_to user.name, user %>
            <% if current_user.admin? %>
              &nbsp;|&nbsp; <%= link_to "基本情報編集", edit_basic_info_user_path(user),
                             class: "text-decoration-none" %>
              <% unless current_user == user %>
                &nbsp;|&nbsp; <%= link_to "削除", user,
                               data: { turbo_method: :delete, turbo_confirm: "#{user.name}を削除しますか？" },
                               class: "text-danger text-decoration-none" %>
              <% end %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= will_paginate @users, renderer: Bootstrap5LinkRenderer,
                   previous_label: "前へ", next_label: "次へ" %>
</div>
